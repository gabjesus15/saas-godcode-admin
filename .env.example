# OpenStreetMap (Nominatim) para geocodificación en servidor.
# No requiere token; puede tener rate limits del proveedor.
OPENSTREET_GEOCODE_COUNTRIES=cl

# Uber Direct (OAuth client credentials, scope eats.deliveries).
# https://developer.uber.com/docs/deliveries/guides/authentication
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=

# Orígenes permitidos para CORS en /api/delivery-quote y /api/public-order-delivery
# (menú en dominio distinto al de las APIs). Lista separada por comas.
# PUBLIC_API_CORS_ORIGINS=https://tu-menu.example.com

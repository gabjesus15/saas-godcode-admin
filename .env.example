# ============================================
# saas-godcode-admin - Variables de entorno
# ============================================
# Copia este archivo como .env.local para desarrollo local.

# ------ Supabase (obligatorias) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Opcional (dashboard Supabase): el cliente usa NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ Multi-tenant (obligatorias) ------
NEXT_PUBLIC_TENANT_BASE_DOMAIN=godcode.me
NEXT_PUBLIC_TENANT_PROTOCOL=https

# ------ URL canonica de la app (recomendada) ------
NEXT_PUBLIC_APP_URL=https://www.godcode.me

# ------ Stripe (pagos con tarjeta) ------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# ------ PayPal (pagos PayPal) ------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# ------ Resend (emails transaccionales) ------
RESEND_API_KEY=re_...
RESEND_FROM=noreply@godcode.me

# ------ reCAPTCHA (onboarding) ------
RECAPTCHA_SECRET_KEY=

# ------ Cron jobs (GET/POST /api/cron/subscription-status) ------
# En produccion (Vercel): obligatorio. Enviar header Authorization: Bearer <CRON_SECRET>.
# En desarrollo: si esta vacio, el endpoint no exige auth (solo usar en local).
CRON_SECRET=

# ------ Emails de equipo ------
ONBOARDING_TEAM_EMAIL=

# ------ Branding de emails (opcional) ------
EMAIL_LOGO_URL=
EMAIL_COMPANY_NAME=GodCode
EMAIL_TAGLINE=Tu vision, nuestro codigo.

# ------ Cloudinary (imagenes, opcional) ------
# Usa un upload preset de tipo "unsigned" para subidas desde el navegador.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ------ Microservicio onboarding-billing ------
# off (false): las rutas /api/onboarding/* del BFF responden 503 (no hay logica local duplicada).
# on (true) o proxy_only: reenvio al micro; sin URL -> 503; micro caido -> 502.
FF_ONBOARDING_BILLING_EXTERNAL=proxy_only
ONBOARDING_BILLING_SERVICE_URL=
SERVICE_API_KEY=

# ------ Legacy / compatibilidad (opcional) ------
NEXT_PUBLIC_PUBLIC_COMPANY_SLUG=
NEXT_PUBLIC_COMPANY_SLUG=

# ------ Next.js (desarrollo local, opcional) ------
# NEXT_DISABLE_TURBOPACK=1

# ------ Panel de duenos (app separada: services/tenant-panel) ------
# URL publica del proyecto tenant-panel (sin barra final). Ej: https://panel.tudominio.com
# Sin esto, el boton de acceso admin en la home del tenant no se muestra.
NEXT_PUBLIC_TENANT_PANEL_URL=


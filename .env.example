# ============================================
# saas-godcode-admin — Variables de entorno
# ============================================
# Copia este archivo como .env y llena los valores.

# ------ Supabase (obligatorias) ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------ Multi-tenant (obligatorias) ------
NEXT_PUBLIC_TENANT_BASE_DOMAIN=godcode.me
NEXT_PUBLIC_TENANT_PROTOCOL=https

# ------ URL canonica de la app ------
NEXT_PUBLIC_APP_URL=https://godcode.me

# ------ Stripe (pagos con tarjeta) ------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_SUCCESS_URL=https://godcode.me/checkout/success
STRIPE_CANCEL_URL=https://godcode.me/onboarding/pago

# ------ PayPal (pagos PayPal) ------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | production
PAYPAL_ENVIRONMENT=sandbox

# ------ Resend (emails transaccionales) ------
RESEND_API_KEY=re_...
RESEND_FROM=noreply@godcode.me

# ------ reCAPTCHA (onboarding) ------
RECAPTCHA_SECRET_KEY=

# ------ Health check (GET /api/health) ------
# Sin token: respuesta publica minima. Con Bearer token: detalles completos.
HEALTH_CHECK_SECRET=

# ------ Cron jobs (/api/cron/subscription-status) ------
# Produccion: obligatorio. Local vacio = sin auth.
CRON_SECRET=

# ------ Emails de equipo ------
ONBOARDING_TEAM_EMAIL=

# ------ Branding de emails (opcional) ------
EMAIL_LOGO_URL=
EMAIL_COMPANY_NAME=GodCode
EMAIL_TAGLINE=Tu vision, nuestro codigo.

# ------ Cloudinary (imagenes) ------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ------ Microservicio onboarding-billing ------
# off / false: 503 en rutas BFF. on / true / proxy_only: proxy al micro.
FF_ONBOARDING_BILLING_EXTERNAL=off
ONBOARDING_BILLING_SERVICE_URL=
SERVICE_API_KEY=

# ------ Uber Direct (delivery) ------
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_CUSTOMER_ID=

# ------ Geocodificacion (OpenStreetMap / Nominatim) ------
OPENSTREET_GEOCODE_COUNTRIES=cl

# ------ CORS para APIs publicas del menu ------
# Lista separada por comas de origenes permitidos.
# PUBLIC_API_CORS_ORIGINS=https://tu-menu.example.com
